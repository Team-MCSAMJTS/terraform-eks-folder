  "outputs": {
    "config_map_aws_auth": {
      "value": "\r\n\r\napiVersion: v1\r\nkind: ConfigMap\r\nmetadata:\r\n  name: aws-auth\r\n  namespace: kube-system\r\ndata:\r\n  mapRoles: |\r\n    - rolearn: arn:aws:iam::050752609092:role/tsp-cluster-node\r\n      username: system:node:{{EC2PrivateDNSName}}\r\n      groups:\r\n        - system:bootstrappers\r\n        - system:nodes\r\n",
      "type": "string"
    },
    "kubeconfig": {
      "value": "\r\n\r\napiVersion: v1\r\nclusters:\r\n- cluster:\r\n    server: https://732C3CF22A4B85605009C011D7E3A92B.gr7.ca-central-1.eks.amazonaws.com\r\n    certificate-authority-data: \r\n  name: kubernetes\r\ncontexts:\r\n- context:\r\n    cluster: kubernetes\r\n    user: aws\r\n  name: aws\r\ncurrent-context: aws\r\nkind: Config\r\npreferences: {}\r\nusers:\r\n- name: aws\r\n  user:\r\n    exec:\r\n      apiVersion: client.authentication.k8s.io/v1beta1\r\n      command: aws-iam-authenticator\r\n      args:\r\n        - \"token\"\r\n        - \"-i\"\r\n        - \"tsp-cluster\"\r\n",
      "type": "string"
    }
  },
